# dispatcher.conf - Dispatcher control host configuration

# mTLS certificate material (required)
cert = /etc/dispatcher/dispatcher.crt
key  = /etc/dispatcher/dispatcher.key
ca   = /etc/dispatcher/ca.crt

# Auth hook - called before every run and ping request.
# The default hook authorises everything. Replace with real logic for
# production use. Comment out to disable auth entirely.
auth_hook = /etc/dispatcher/auth-hook

# Request timeout in seconds (default: 60)
# timeout = 60

# Cert lifetime in days for newly signed agent certs (default: 365).
# Agents are automatically renewed when remaining validity drops below
# half this value. A cert that goes unused for the full lifetime expires,
# which is the correct behaviour for a decommissioned host.
cert_days = 365

# API server TLS (optional - plain HTTP if not set)
# api_cert = /etc/dispatcher/dispatcher.crt
# api_key  = /etc/dispatcher/dispatcher.key
