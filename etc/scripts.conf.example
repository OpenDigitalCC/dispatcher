# dispatcher-agent script allowlist
# /etc/dispatcher-agent/scripts.conf
#
# One entry per line: <name>  <absolute-path>
# The name is what the dispatcher passes as the script argument.
# The path must be executable and owned by root.
#
# Example:
#   backup-mysql    /opt/dispatcher-scripts/backup-mysql.sh
#   deploy-app      /opt/dispatcher-scripts/deploy-app.sh

# --- Demonstrator (evaluation and examples) ---
#
# The dispatcher-demonstrator script illustrates core dispatcher capabilities:
# stdout/stderr capture, exit code propagation, argument passing, JSON context,
# and agent-side information. Run the script directly on the agent host to see
# available subcommands and the dispatcher invocations that exercise them.
#
# Uncomment to enable:
# dispatcher-demonstrator  /opt/dispatcher-scripts/dispatcher-demonstrator.sh
