# ctrl-exec-agent script allowlist
# /etc/ctrl-exec-agent/scripts.conf
#
# One entry per line: <name> = <absolute-path>
# The name is what the ctrl-exec passes as the script argument.
# The path must be executable and owned by root.
#
# Example:
#   backup-mysql = /opt/ctrl-exec-scripts/backup-mysql.sh
#   deploy-app   = /opt/ctrl-exec-scripts/deploy-app.sh

# --- Demonstrator (evaluation and examples) ---
#
# The ctrl-exec-demonstrator script illustrates core ctrl-exec capabilities:
# stdout/stderr capture, exit code propagation, argument passing, JSON context,
# and agent-side information. Run the script directly on the agent host to see
# available subcommands and the ctrl-exec invocations that exercise them.
#
# Uncomment to enable:
# ctrl-exec-demonstrator = /opt/ctrl-exec-scripts/ctrl-exec-demonstrator.sh

# --- Dispatcher certificate rotation ---
#
# Required for automatic ctrl-exec cert rotation. When the ctrl-exec
# rotates its certificate, it calls this script on each agent to update
# the stored ctrl-exec serial and reload the agent configuration.
# Without this entry, the agent will not receive serial updates and will
# eventually require manual re-pairing after the overlap window expires.
#
# The script is installed at /opt/ctrl-exec-scripts/update-ctrl-exec-serial
# by the agent installer.
#
# Uncomment to enable:
# update-ctrl-exec-serial = /opt/ctrl-exec-scripts/update-ctrl-exec-serial
