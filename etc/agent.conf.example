# dispatcher-agent configuration
# /etc/dispatcher-agent/agent.conf

port = 7443
cert = /etc/dispatcher-agent/agent.crt
key  = /etc/dispatcher-agent/agent.key
ca   = /etc/dispatcher-agent/ca.crt

# Dispatcher certificate CN for capabilities access control.
# The /capabilities endpoint is restricted to connections presenting a cert
# whose CN matches this value. Set to the CN used when running setup-dispatcher
# on the dispatcher host (default: 'dispatcher').
# dispatcher_cn = dispatcher

# Restrict scripts to approved directories (optional, recommended).
# Colon-separated list of absolute directory paths.
# If set, any script path in scripts.conf not under an approved directory
# is rejected at load time and re-validated at execution time.
#
# script_dirs = /opt/dispatcher-scripts:/usr/local/lib/dispatcher-scripts

# Agent-side auth hook (optional).
# Called before every run request, after allowlist validation.
# Receives full request context including username and token, enabling
# independent downstream token validation separate from the dispatcher's
# own auth hook.
# Hook must be executable. Exit 0 = authorised, 1/2/3 = denied.
# See /etc/dispatcher/auth-hook.example for the hook interface.
#
# auth_hook = /etc/dispatcher-agent/auth-hook

# Agent tags - reported in /capabilities response and dispatcher discovery.
# Use to group and filter agents by environment, role, location, etc.
#
# [tags]
# env  = prod
# role = db
# site = london
