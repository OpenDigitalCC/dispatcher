#!/bin/bash
# auth-hook.example - Dispatcher authorisation hook
#
# This hook is called before every run and ping request, from both the
# CLI and the API. It receives request context as environment variables
# and as a JSON object on stdin.
#
# Environment variables:
#   DISPATCHER_ACTION      run | ping | api
#   DISPATCHER_SCRIPT      script name (empty for ping and api requests)
#   DISPATCHER_HOSTS       comma-separated host list
#   DISPATCHER_ARGS_JSON   script args as a JSON array (use this)
#   DISPATCHER_USERNAME    username from request (may be empty)
#   DISPATCHER_TOKEN       token from request (may be empty)
#   DISPATCHER_SOURCE_IP   originating IP address
#   DISPATCHER_TIMESTAMP   ISO8601 UTC timestamp
#
# DISPATCHER_ARGS (space-joined) is also set for backward compatibility
# but is deprecated. It is lossy for args containing spaces or newlines.
# Always use DISPATCHER_ARGS_JSON for argument inspection.
#
# stdin: full request context as a JSON object (same fields as above,
#        with hosts and args as arrays)
#
# Exit codes:
#   0   authorised
#   1   denied - generic
#   2   denied - bad credentials
#   3   denied - insufficient privilege
#
# The hook must not produce output on stdout or stderr.
# Use syslog for audit logging within the hook.
#
# --- Examples below. Replace with real logic for production use. ---

# Example 1: Deny everything (safe default - uncomment to use)
# exit 1

# Example 2: Allow everything (isolated network only - uncomment to use)
# exit 0

# Example 3: Token-based authorisation
# Requires DISPATCHER_TOKEN to be set and match a known value.
# Suitable when callers supply a shared secret token.
#
# REQUIRED_TOKEN="changeme"
# if [ "$DISPATCHER_TOKEN" != "$REQUIRED_TOKEN" ]; then
#     logger -t dispatcher-auth "denied: bad token for $DISPATCHER_ACTION from $DISPATCHER_SOURCE_IP"
#     exit 2
# fi
# exit 0

# Example 4: Restrict run actions to specific scripts
# Allows ping and api actions freely; restricts run to named scripts.
#
# if [ "$DISPATCHER_ACTION" = "run" ]; then
#     case "$DISPATCHER_SCRIPT" in
#         deploy-app|restart-service|backup-db)
#             exit 0
#             ;;
#         *)
#             logger -t dispatcher-auth "denied: script '$DISPATCHER_SCRIPT' not permitted"
#             exit 1
#             ;;
#     esac
# fi
# exit 0

# Example 5: Inspect args using DISPATCHER_ARGS_JSON
# Requires jq. Denies run if more than 3 args are supplied.
#
# if [ "$DISPATCHER_ACTION" = "run" ]; then
#     arg_count=$(echo "$DISPATCHER_ARGS_JSON" | jq 'length')
#     if [ "$arg_count" -gt 3 ]; then
#         logger -t dispatcher-auth "denied: too many args ($arg_count)"
#         exit 1
#     fi
# fi
# exit 0

# Default: deny all. Configure a hook appropriate to your environment.
exit 1
