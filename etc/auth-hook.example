#!/bin/bash
# auth-hook.example - ctrl-exec authorisation hook
#
# This hook is called before every run and ping request, from both the
# CLI and the API. It receives request context as environment variables
# and as a JSON object on stdin.
#
# Environment variables:
#   ENVEXEC_ACTION      run | ping
#   ENVEXEC_SCRIPT      script name (empty for ping and api requests)
#   ENVEXEC_HOSTS       comma-separated host list
#   ENVEXEC_ARGS_JSON   script args as a JSON array (use this)
#   ENVEXEC_USERNAME    username from request (may be empty)
#   ENVEXEC_TOKEN       token from request (may be empty)
#   ENVEXEC_SOURCE_IP   originating IP address
#   ENVEXEC_TIMESTAMP   ISO8601 UTC timestamp
#
# ENVEXEC_ARGS (space-joined) is also set for backward compatibility
# but is deprecated. It is lossy for args containing spaces or newlines.
# Always use ENVEXEC_ARGS_JSON for argument inspection.
#
# stdin: full request context as a JSON object (same fields as above,
#        with hosts and args as arrays)
#
# Exit codes:
#   0   authorised
#   1   denied - generic
#   2   denied - bad credentials
#   3   denied - insufficient privilege
#
# The hook must not produce output on stdout or stderr.
# Use syslog for audit logging within the hook.
#
# --- Examples below. Replace with real logic for production use. ---

# Example 1: Deny everything (safe default - uncomment to use)
# exit 1

# Example 2: Allow everything (isolated network only - uncomment to use)
# exit 0

# Example 3: Token-based authorisation
# Requires ENVEXEC_TOKEN to be set and match a known value.
# Suitable when callers supply a shared secret token.
#
# REQUIRED_TOKEN="changeme"
# if [ "$ENVEXEC_TOKEN" != "$REQUIRED_TOKEN" ]; then
#     logger -t ctrl-exec-auth "denied: bad token for $ENVEXEC_ACTION from $ENVEXEC_SOURCE_IP"
#     exit 2
# fi
# exit 0

# Example 4: Restrict run actions to specific scripts
# Bypasses access checks for all non-run actions (e.g. ping); restricts run to named scripts.
#
# if [ "$ENVEXEC_ACTION" = "run" ]; then
#     case "$ENVEXEC_SCRIPT" in
#         deploy-app|restart-service|backup-db)
#             exit 0
#             ;;
#         *)
#             logger -t ctrl-exec-auth "denied: script '$ENVEXEC_SCRIPT' not permitted"
#             exit 1
#             ;;
#     esac
# fi
# exit 0

# Example 5: Inspect args using ENVEXEC_ARGS_JSON
# Requires jq. Denies run if more than 3 args are supplied.
#
# if [ "$ENVEXEC_ACTION" = "run" ]; then
#     arg_count=$(echo "$ENVEXEC_ARGS_JSON" | jq 'length')
#     if [ "$arg_count" -gt 3 ]; then
#         logger -t ctrl-exec-auth "denied: too many args ($arg_count)"
#         exit 1
#     fi
# fi
# exit 0

# Default: deny all. Configure a hook appropriate to your environment.
exit 1
