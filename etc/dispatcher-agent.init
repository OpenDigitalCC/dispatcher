#!/bin/sh /etc/rc.common
# dispatcher-agent - procd init script for OpenWrt
# Install to /etc/init.d/dispatcher-agent

USE_PROCD=1

# Start after network (80) and syslog (60); stop before network teardown
START=95
STOP=15

AGENT_BIN="/usr/local/bin/dispatcher-agent"
AGENT_USER="dispatcher-agent"
AGENT_CONF="/etc/dispatcher-agent/agent.conf"

start_service() {
    # Refuse to start if binary or config are absent
    [ -f "$AGENT_BIN" ]  || { logger -t dispatcher-agent "Binary not found: $AGENT_BIN"; return 1; }
    [ -f "$AGENT_CONF" ] || { logger -t dispatcher-agent "Config not found: $AGENT_CONF"; return 1; }

    procd_open_instance
    procd_set_param command "$AGENT_BIN" serve

    procd_set_param user "$AGENT_USER"

    # Restart on failure: check every 3600s, restart after 5s, no retry limit
    procd_set_param respawn 3600 5 0

    # Suppress stdout; stderr goes to logd -> syslog (matches systemd unit behaviour)
    procd_set_param stdout 0
    procd_set_param stderr 1

    procd_close_instance
}

stop_service() {
    # procd handles SIGTERM; this hook exists for any cleanup needed on stop
    return 0
}

reload_service() {
    # Send SIGHUP to trigger config reload (allowlist, auth hook, tags)
    local pid
    pid=$(pgrep -f "$AGENT_BIN serve" 2>/dev/null) || return 0
    kill -HUP "$pid"
}
