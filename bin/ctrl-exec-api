#!/usr/bin/perl

use strict;
use warnings;
use FindBin qw($Bin);
use lib "$Bin/../lib";

use Exec::Log qw();
use Exec::API qw();
use Getopt::Long    qw(GetOptions);

our $VERSION = 'UNINSTALLED';

my $CONFIG_PATH = '/etc/ctrl-exec/ctrl-exec.conf';

main();

sub main {
    GetOptions('config=s' => \$CONFIG_PATH)
        or die usage();

    Exec::Log::init('ctrl-exec-api');

    my $config = load_config($CONFIG_PATH);

    Exec::API::run(config => $config);
}

sub load_config {
    my ($path) = @_;
    open my $fh, '<', $path
        or die "Cannot open config '$path': $!\n";
    my %config;
    while (my $line = <$fh>) {
        chomp $line;
        next if $line =~ /^\s*[#\s]/;
        $config{$1} = $2 if $line =~ /^\s*(\w+)\s*=\s*(.+?)\s*$/;
    }
    close $fh;
    for my $k (qw(cert key ca)) {
        die "Missing '$k' in $path\n" unless $config{$k};
    }
    return \%config;
}

sub usage {
    return <<'END';
Usage: ctrl-exec-api [options]

Options:
  --config <path>    Path to ctrl-exec.conf (default /etc/ctrl-exec/ctrl-exec.conf)

The API server reads its configuration from ctrl-exec.conf.
Relevant keys:
  api_port   Port to listen on (default 7445)
  api_cert   TLS certificate (optional - plain HTTP if absent)
  api_key    TLS private key  (optional - plain HTTP if absent)
  auth_hook  Auth hook executable (optional)
END
}
