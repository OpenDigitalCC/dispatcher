#!/usr/bin/perl

use strict;
use warnings;
use FindBin qw($Bin);
use lib "$Bin/../lib";

use Dispatcher::Agent::Config  qw();
use Dispatcher::Agent::Runner  qw();
use Dispatcher::Agent::Pairing qw();
use Dispatcher::Auth           qw();
use Dispatcher::Log            qw();
use JSON                       qw(encode_json decode_json);
use POSIX                      qw(SIGTERM WNOHANG strftime);
use Sys::Hostname              qw(hostname);
use Getopt::Long               qw(GetOptions);

our $VERSION = 'UNINSTALLED';

my $CONFIG_PATH    = '/etc/dispatcher-agent/agent.conf';
my $ALLOWLIST_PATH = '/etc/dispatcher-agent/scripts.conf';

# --- entry point ---

main();

sub main {
    my ($mode, %opts);

    GetOptions(
        'config=s'      => \$CONFIG_PATH,
        'allowlist=s'   => \$ALLOWLIST_PATH,
        'dispatcher=s'  => \$opts{dispatcher},
        'port=i'        => \$opts{port},
    ) or die usage();

    $mode = shift @ARGV // 'serve';

    Dispatcher::Log::init('dispatcher-agent');

    my %dispatch = (
        serve             => \&mode_serve,
        'request-pairing' => \&mode_request_pairing,
        'pairing-status'  => \&mode_pairing_status,
        'ping-self'       => \&mode_ping_self,
    );

    my $handler = $dispatch{$mode}
        or die "Unknown mode '$mode'\n" . usage();

    $handler->(\%opts);
}

# --- modes ---

sub mode_serve {
    my ($opts) = @_;

    my $config    = Dispatcher::Agent::Config::load_config($CONFIG_PATH);
    my $allowlist = Dispatcher::Agent::Config::load_allowlist($ALLOWLIST_PATH);

    my $revoked_path = $config->{revoked_serials}
                    // '/etc/dispatcher-agent/revoked-serials';
    my $revoked = Dispatcher::Agent::Pairing::load_revoked_serials(
        path => $revoked_path,
    );

    my $disp_serial_path = $config->{dispatcher_serial_path}
                        // '/etc/dispatcher-agent/dispatcher-serial';
    my $disp_serial = Dispatcher::Agent::Pairing::load_dispatcher_serial(
        path => $disp_serial_path,
    );

    $SIG{HUP} = sub {
        warn "Reloading allowlist, revocation list, and dispatcher serial...\n";
        $allowlist = eval { Dispatcher::Agent::Config::load_allowlist($ALLOWLIST_PATH) };
        warn "Allowlist reload failed: $@\n" if $@;
        $revoked = eval {
            Dispatcher::Agent::Pairing::load_revoked_serials(path => $revoked_path)
        };
        warn "Revocation list reload failed: $@\n" if $@;
        $disp_serial = eval {
            Dispatcher::Agent::Pairing::load_dispatcher_serial(path => $disp_serial_path)
        };
        warn "Dispatcher serial reload failed: $@\n" if $@;
    };

    require IO::Socket::SSL;

    my $server = IO::Socket::SSL->new(
        LocalPort       => $config->{port},
        Listen          => 10,
        ReuseAddr       => 1,
        SSL_cert_file   => $config->{cert},
        SSL_key_file    => $config->{key},
        SSL_ca_file     => $config->{ca},
        SSL_verify_mode => IO::Socket::SSL::SSL_VERIFY_PEER(),
    ) or die "Cannot start server: $IO::Socket::SSL::SSL_ERROR\n";

    Dispatcher::Log::log_action('INFO', {
        ACTION => 'start',
        PORT   => $config->{port},
    });

    while (my $conn = $server->accept) {
        my $peer = $conn->peerhost // 'unknown';
        my $pid  = fork();
        if (!defined $pid) {
            warn "fork failed: $!\n";
            $conn->close(SSL_no_shutdown => 1);
            next;
        }
        if ($pid == 0) {
            # Child: close server socket, handle connection, exit
            $server->close(SSL_no_shutdown => 1);
            handle_connection($conn, $peer, $allowlist, $config, $revoked, $disp_serial);
            $conn->close;
            exit 0;
        }
        # Parent: release fd without SSL shutdown so child owns it
        $conn->close(SSL_no_shutdown => 1);
        waitpid -1, WNOHANG();
    }
}

sub mode_request_pairing {
    my ($opts) = @_;

    my $dispatcher = $opts->{dispatcher}
        or die "--dispatcher <host> required for request-pairing\n";

    my $host = hostname();

    print "Generating key and CSR for '$host'...\n";
    my $pair = Dispatcher::Agent::Pairing::generate_key_and_csr(
        hostname => $host,
    );

    # Compute a 6-digit confirmation code from the CSR for the operator
    # to verify against the dispatcher's display before approving.
    my $pairing_code = _pairing_code($pair->{csr_pem});
    print "Pairing code: $pairing_code\n";
    print "  Verify this code matches the dispatcher display before approving.\n\n";

    print "Connecting to dispatcher at $dispatcher for pairing...\n";
    my $result = Dispatcher::Agent::Pairing::request_pairing(
        dispatcher => $dispatcher,
        port       => $opts->{port} // 7444,
        csr_pem    => $pair->{csr_pem},
        hostname   => $host,
    );

    unless ($result->{ok}) {
        my $err = $result->{error} // 'unknown error';
        if ($err =~ /IO::Socket::IP configuration failed|Name or service not known|Temporary failure in name resolution/i) {
            die "Pairing failed: could not resolve dispatcher hostname '$dispatcher'.\n"
              . "Check the hostname is correct or use an IP address instead.\n";
        }
        if ($err =~ /connect failed|connection refused|No route to host/i) {
            die "Pairing failed: could not connect to dispatcher at $dispatcher.\n"
              . "Check the dispatcher address is correct and pairing mode is active:\n"
              . "  sudo dispatcher pairing-mode\n";
        }
        die "Pairing failed: $err\n";
    }

    Dispatcher::Agent::Pairing::store_certs(
        cert_pem          => $result->{cert_pem},
        ca_pem            => $result->{ca_pem},
        key_pem           => $pair->{key_pem},
        dispatcher_serial => $result->{dispatcher_serial} // '',
    );

    Dispatcher::Log::log_action('INFO', {
        ACTION     => 'pair-complete',
        STATUS     => 'approved',
        DISPATCHER => $dispatcher,
    });

    print "Pairing complete. Certificates stored.\n";
}

sub mode_pairing_status {
    my $status = Dispatcher::Agent::Pairing::pairing_status();
    if ($status->{paired}) {
        print "Paired. Certificate expires: $status->{expiry}\n";
    }
    else {
        print "Not paired. Reason: $status->{reason}\n";
        exit 1;
    }
}

sub mode_ping_self {
    print "Checking config...\n";
    my $config = eval { Dispatcher::Agent::Config::load_config($CONFIG_PATH) };
    if ($@) { print "Config error: $@\n"; exit 1; }
    print "  Config OK (port $config->{port})\n";

    my $allowlist = eval { Dispatcher::Agent::Config::load_allowlist($ALLOWLIST_PATH) };
    if ($@) { print "Allowlist error: $@\n"; exit 1; }
    printf "  Allowlist OK (%d scripts)\n", scalar keys %$allowlist;

    my $status = Dispatcher::Agent::Pairing::pairing_status();
    if ($status->{paired}) {
        print "  Certs OK (expires $status->{expiry})\n";
    }
    else {
        print "  Certs: NOT paired - $status->{reason}\n";
    }

    for my $name (sort keys %$allowlist) {
        my $path = $allowlist->{$name};
        my $ok   = -x $path ? 'ok' : 'NOT EXECUTABLE';
        print "  Script '$name': $path [$ok]\n";
    }

    print "Self-check complete.\n";
}

# --- connection handler (runs in forked child) ---
# Reads raw HTTP/1.0 request from IO::Socket::SSL, dispatches, sends response.

sub handle_connection {
    my ($conn, $peer, $allowlist, $config, $revoked, $disp_serial) = @_;

    # Check peer cert serial against the revocation list before any routing.
    # A revoked cert is rejected regardless of what it would have been allowed
    # to do. The check happens after the mTLS handshake (which verified the CA
    # signature) - revocation is a post-authentication deny.
    my $peer_serial = _peer_serial($conn);

    if (length $peer_serial &&
        Dispatcher::Agent::Pairing::serial_revoked($peer_serial, $revoked)) {
        Dispatcher::Log::log_action('WARNING', {
            ACTION => 'revoked-cert',
            PEER   => $peer,
            SERIAL => $peer_serial,
        });
        _send_raw($conn, 403, encode_json({ error => 'certificate revoked' }));
        return;
    }

    # Read request line
    my $request_line = <$conn>;
    unless ($request_line) {
        _send_raw($conn, 400, encode_json({ error => 'empty request' }));
        return;
    }
    chomp $request_line;
    $request_line =~ s/\r//;

    my ($method, $path) = split ' ', $request_line;

    # Read headers
    my %headers;
    while (my $line = <$conn>) {
        $line =~ s/\r\n$//;
        $line =~ s/\n$//;
        last if $line eq '';
        if ($line =~ /^([^:]+):\s*(.*)$/) {
            $headers{ lc $1 } = $2;
        }
    }

    # Read body
    my $body = '';
    if (my $len = $headers{'content-length'}) {
        read $conn, $body, $len;
    }

    if ($method eq 'POST' && $path eq '/run') {
        handle_run($conn, $body, $peer, $allowlist, $config);
    }
    elsif ($method eq 'POST' && $path eq '/ping') {
        handle_ping($conn, $body, $peer);
    }
    elsif ($method eq 'GET' && $path eq '/capabilities') {
        handle_capabilities($conn, $peer, $allowlist, $config, $disp_serial);
    }
    else {
        _send_raw($conn, 404, encode_json({ error => 'not found' }));
    }
}

sub handle_run {
    my ($conn, $body, $peer, $allowlist, $config) = @_;

    my $data = eval { decode_json($body) };
    if ($@) {
        _send_json($conn, { exit => -1, error => 'invalid JSON' });
        return;
    }

    my $name     = $data->{script}   // '';
    my $args     = $data->{args}     // [];
    my $reqid    = $data->{reqid}    // '';
    my $username = $data->{username} // '';
    my $token    = $data->{token}    // '';

    unless (ref $args eq 'ARRAY') {
        _send_json($conn, { exit => -1, error => 'args must be an array', reqid => $reqid });
        return;
    }

    my $script_path = Dispatcher::Agent::Config::validate_script(
        $name, $allowlist, $config->{script_dirs}
    );

    unless ($script_path) {
        Dispatcher::Log::log_action('WARNING', {
            ACTION => 'deny',
            SCRIPT => $name,
            PEER   => $peer,
            REQID  => $reqid,
        });
        _send_json($conn, {
            script => $name,
            exit   => -1,
            error  => 'script not permitted',
            reqid  => $reqid,
        });
        return;
    }

    # Agent auth hook - called after allowlist validation
    if ($config->{auth_hook}) {
        my $auth = Dispatcher::Auth::check(
            action    => 'run',
            config    => $config,
            script    => $name,
            args      => $args,
            username  => $username,
            token     => $token,
            source_ip => $peer,
        );
        unless ($auth->{ok}) {
            Dispatcher::Log::log_action('WARNING', {
                ACTION => 'deny',
                REASON => $auth->{reason},
                SCRIPT => $name,
                PEER   => $peer,
                REQID  => $reqid,
            });
            _send_json($conn, {
                script => $name,
                exit   => -1,
                error  => 'not authorised: ' . $auth->{reason},
                reqid  => $reqid,
            });
            return;
        }
    }

    my $context = {
        script    => $name,
        args      => $args,
        reqid     => $reqid,
        peer_ip   => $peer,
        username  => $username,
        token     => $token,
        timestamp => POSIX::strftime('%Y-%m-%dT%H:%M:%SZ', gmtime),
    };

    my $result = Dispatcher::Agent::Runner::run_script($script_path, $args, $context);

    Dispatcher::Log::log_action('INFO', {
        ACTION => 'run',
        SCRIPT => $name,
        EXIT   => $result->{exit},
        PEER   => $peer,
        REQID  => $reqid,
    });

    _send_json($conn, {
        script => $name,
        exit   => $result->{exit},
        stdout => $result->{stdout},
        stderr => $result->{stderr},
        reqid  => $reqid,
    });
}

sub handle_ping {
    my ($conn, $body, $peer) = @_;

    my $data  = eval { decode_json($body) } // {};
    my $reqid = $data->{reqid} // '';

    my $status = Dispatcher::Agent::Pairing::pairing_status();

    Dispatcher::Log::log_action('INFO', {
        ACTION => 'ping',
        PEER   => $peer,
        REQID  => $reqid,
    });

    _send_json($conn, {
        status  => 'ok',
        host    => hostname(),
        version => $VERSION,
        expiry  => $status->{expiry} // 'unknown',
        reqid   => $reqid,
    });
}

sub handle_capabilities {
    my ($conn, $peer, $allowlist, $config, $disp_serial) = @_;

    # Restrict /capabilities to the genuine dispatcher cert.
    # The stored serial was recorded at pairing time from the dispatcher's
    # own cert. Any CA-signed peer whose serial does not match is rejected -
    # this closes lateral reconnaissance from a compromised agent peer.
    #
    # If no serial is stored (agent not yet paired, or pre-serial-tracking
    # pairing), the check is skipped with a warning. Re-pair to enable it.
    if (length $disp_serial) {
        my $peer_serial = eval {
            _peer_serial($conn)
        } // '';

        unless (length $peer_serial && $peer_serial eq $disp_serial) {
            Dispatcher::Log::log_action('WARNING', {
                ACTION      => 'capabilities-deny',
                PEER        => $peer,
                PEER_SERIAL => $peer_serial,
                REASON      => 'serial-mismatch',
            });
            _send_raw($conn, 403, encode_json({ error => 'forbidden' }));
            return;
        }
    }
    else {
        Dispatcher::Log::log_action('WARNING', {
            ACTION => 'capabilities-no-serial',
            PEER   => $peer,
            REASON => 'no dispatcher serial stored - re-pair to enable restriction',
        });
    }

    my @scripts;
    for my $name (sort keys %$allowlist) {
        my $path = $allowlist->{$name};
        push @scripts, {
            name       => $name,
            path       => $path,
            executable => (-x $path ? JSON::true : JSON::false),
        };
    }

    Dispatcher::Log::log_action('INFO', {
        ACTION  => 'capabilities',
        PEER    => $peer,
        SCRIPTS => scalar @scripts,
    });

    _send_json($conn, {
        status  => 'ok',
        host    => hostname(),
        version => $VERSION,
        scripts => \@scripts,
    });
}

# Extract the peer certificate serial number from an IO::Socket::SSL
# connection as a lowercase hex string.
# IO::Socket::SSL's peer_certificate('serialNumber') is not supported in
# all versions - use Net::SSLeay directly to read the ASN1 integer.
# Returns '' if no peer cert or serial cannot be read.
sub _peer_serial {
    my ($conn) = @_;
    my $ssl  = eval { $conn->_get_ssl_object } or return '';
    my $cert = eval { Net::SSLeay::get_peer_certificate($ssl) } or return '';
    my $asn1 = eval { Net::SSLeay::X509_get_serialNumber($cert) } or return '';
    my $hex  = eval { Net::SSLeay::P_ASN1_INTEGER_get_hex($asn1) } // '';
    return lc $hex;
}

sub _send_json {
    my ($conn, $data) = @_;
    _send_raw($conn, 200, encode_json($data));
}

sub _send_raw {
    my ($conn, $code, $body) = @_;
    my %status_text = (200 => 'OK', 400 => 'Bad Request', 404 => 'Not Found');
    my $text = $status_text{$code} // 'Error';
    print $conn
        "HTTP/1.0 $code $text\r\n",
        "Content-Type: application/json\r\n",
        "Content-Length: ", length($body), "\r\n",
        "\r\n",
        $body;
}

# Compute a 6-digit confirmation code from a CSR PEM string.
# The same computation on the dispatcher side produces an identical code,
# allowing the operator to verify the request visually without any
# out-of-band channel.
sub _pairing_code {
    my ($csr_pem) = @_;
    # Use openssl for SHA256 - avoids Digest::SHA dependency on minimal
    # Perl installations (OpenWrt, embedded systems).
    # Write CSR to a temp file and pipe through openssl dgst -binary.
    require File::Temp;
    my ($tmp_fh, $tmp_path) = File::Temp::tempfile(UNLINK => 1);
    print $tmp_fh $csr_pem;
    close $tmp_fh;
    my $digest = `openssl dgst -sha256 -binary \Q$tmp_path\E 2>/dev/null`;
    die "openssl dgst failed\n" unless length($digest) == 32;
    # Take first 4 bytes as a 32-bit unsigned int, modulo 1,000,000
    my $n = unpack('N', substr($digest, 0, 4)) % 1_000_000;
    return sprintf '%06d', $n;
}

sub usage {
    return <<'END';
Usage: dispatcher-agent <mode> [options]

Modes:
  serve                          Start the agent server (default)
  request-pairing --dispatcher <host>
                                 Request pairing with a dispatcher host
  pairing-status                 Show pairing/cert status
  ping-self                      Validate local config and certs

Options:
  --config <path>                Path to agent.conf
  --allowlist <path>             Path to scripts.conf
  --port <n>                     Override pairing port (default 7444)
END
}
