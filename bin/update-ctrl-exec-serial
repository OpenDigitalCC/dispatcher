#!/bin/bash
# update-ctrl-exec-serial - Update stored ctrl-exec certificate serial
#
# Called by the ctrl-exec during certificate rotation to push the new
# serial to this agent. The agent uses the stored serial to restrict
# /capabilities queries to the genuine ctrl-exec only.
#
# Usage: update-ctrl-exec-serial <hex-serial>
#
# The serial is written to the configured ctrl-exec-serial file and the
# agent is sent SIGHUP to reload without restarting.
#
# TRUST REQUIREMENT: This script performs a privileged operation - it
# overwrites the stored ctrl-exec serial, which controls which ctrl-exec
# cert is trusted for /capabilities. It should only be added to the agent
# scripts.conf allowlist on agents where ctrl-exec cert rotation is in use.
# Any caller able to invoke this script via the run mechanism already holds a
# valid mTLS cert signed by the CA; the risk is bounded by the CA trust model.
# Do not add this to allowlists as a convenience on agents where rotation is
# not configured.
#
# This script is called via the ctrl-exec run mechanism and is
# authenticated by the existing mTLS trust. It should be in scripts.conf
# on every agent that participates in automatic cert rotation.
#
# Exit codes:
#   0   success
#   1   usage error
#   2   write failed
#   3   reload failed

set -euo pipefail

SERIAL_FILE="/etc/ctrl-exec-agent/ctrl-exec-serial"
AGENT_PID_FILE="/run/ctrl-exec-agent.pid"

# Allow override via environment for non-standard installations
SERIAL_FILE="${DISPATCHER_SERIAL_FILE:-$SERIAL_FILE}"

# --- argument validation ---

if [ $# -ne 1 ]; then
    echo "Usage: update-ctrl-exec-serial <hex-serial>" >&2
    exit 1
fi

NEW_SERIAL="$1"

# Validate: must be a non-empty hex string
if ! echo "$NEW_SERIAL" | grep -qE '^[0-9a-fA-F]+$'; then
    echo "Invalid serial format: must be hex string" >&2
    exit 1
fi

# Validate: length must be 8–40 hex characters (4–20 octets, per RFC 5280)
SERIAL_LEN="${#NEW_SERIAL}"
if [ "$SERIAL_LEN" -lt 8 ] || [ "$SERIAL_LEN" -gt 40 ]; then
    echo "Invalid serial length: expected 8–40 hex characters, got $SERIAL_LEN" >&2
    exit 1
fi

# Normalise to lowercase
NEW_SERIAL="${NEW_SERIAL,,}"

# --- write serial file ---

SERIAL_DIR="$(dirname "$SERIAL_FILE")"
if [ ! -d "$SERIAL_DIR" ]; then
    echo "Serial directory '$SERIAL_DIR' does not exist" >&2
    exit 2
fi

# Write atomically via temp file in same directory
TMP_FILE=$(mktemp "$SERIAL_DIR/.ctrl-exec-serial.XXXXXX")
echo "$NEW_SERIAL" > "$TMP_FILE"
chmod 0644 "$TMP_FILE"
mv "$TMP_FILE" "$SERIAL_FILE"

# --- reload agent ---
# Send SIGHUP to reload the serial file without restarting.
# Try pidfile first, then pidof as fallback.

AGENT_PID=""
if [ -f "$AGENT_PID_FILE" ]; then
    AGENT_PID=$(cat "$AGENT_PID_FILE" 2>/dev/null)
fi
if [ -z "$AGENT_PID" ]; then
    AGENT_PID=$(pidof ctrl-exec-agent 2>/dev/null || true)
fi

if [ -n "$AGENT_PID" ]; then
    if kill -HUP "$AGENT_PID" 2>/dev/null; then
        echo "Serial updated to ${NEW_SERIAL}. Agent reloaded (pid $AGENT_PID)."
        exit 0
    else
        echo "Serial written but SIGHUP to pid $AGENT_PID failed." >&2
        echo "Reload manually: kill -HUP \$(pidof ctrl-exec-agent)" >&2
        exit 3
    fi
else
    echo "Serial written but agent process not found - reload manually." >&2
    exit 3
fi
